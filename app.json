{
  "expo": {
    "name": "Janmanindia Community",
    "slug": "janmanindia-community",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "janmanindia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.janmanindia.community"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "org.janmanindia.community"
    },
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-av"],
    "extra": {
      "apiBase": "https://app.janmanindia.org"
    }
  }
}
