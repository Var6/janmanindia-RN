{
  "expo": {
    "name": "Janmanindia Community",
    "slug": "janmanindia",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "janmanindia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.janmanindia.community"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "org.janmanindia.community",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-av",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Janman accesses your photos so you can attach a photo of your government ID for verification.",
          "cameraPermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "apiBase": "https://app.janmanindia.org",
      "eas": {
        "projectId": "eac6f57e-ed53-4a5d-899f-ddc4d60a9bbe"
      }
    },
    "owner": "rishabh_stark"
  }
}
